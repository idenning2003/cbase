{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/src/**/public/"
            ],
            "defines": ["_XOPEN_SOURCE", "_BSD_SOURCE"],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c23",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "${default}",
            "compilerArgs": [
                "-Wall -Wextra -Werror -gdwarf-4 -g3"
            ]
        }
    ],
    "version": 4
}