{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "/usr/include/",
                "${workspaceFolder}/**",
                "${workspaceFolder}/src/**/public/"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c23",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "${default}",
            "compilerArgs": [
                "-Wall -Wextra -Werror -gdwarf-4 -g3"
            ],
            "configurationProvider": "ms-vscode.makefile-tools"
        }
    ],
    "version": 4
}